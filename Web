<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PlsHub Script</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            padding: 0;
            background-color: #0b0d12;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            display: block;
            text-align: center;
        }
        .container {
            max-width: 480px;
            margin: 0 auto;
            padding: 40px 16px;
        }
        .badge {
            background-color: rgba(138, 43, 226, 0.15);
            border: 1px solid #772ce8;
            color: #bd93f9;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 10pt;
            font-weight: 700;
            letter-spacing: 1px;
            display: inline-block;
            margin-bottom: 24px;
            text-transform: uppercase;
        }
        h1 {
            font-size: 28pt;
            margin: 0 0 16px 0;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.5px;
        }
        .subtitle {
            color: #949ba8;
            font-size: 11pt;
            line-height: 1.5;
            margin-bottom: 40px;
            padding: 0 10px;
        }
        .card {
            background-color: #12141c;
            border: 1px solid #1e2230;
            border-radius: 24px;
            overflow: hidden;
            text-align: left;
            box-shadow: 0 12px 32px rgba(0,0,0,0.6);
        }
        .image-container {
            width: 100%;
            position: relative;
            padding-top: 52%;
            background-image: url('dragon.jpg');
            background-size: cover;
            background-position: center;
            background-color: #161924;
        }
        .card-content {
            padding: 24px;
        }
        .game-badge {
            background-color: #1c162e;
            color: #9966ff;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 9pt;
            font-weight: 700;
            display: inline-block;
            margin-bottom: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .card-title {
            font-size: 18pt;
            font-weight: 700;
            margin: 0 0 8px 0;
            color: #ffffff;
        }
        .card-desc {
            color: #7d8594;
            font-size: 11pt;
            line-height: 1.4;
            margin-bottom: 24px;
        }
        .btn-purple {
            background-color: #8a2be2;
            color: #ffffff;
            border: none;
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            font-size: 12pt;
            font-weight: 700;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.1s;
            outline: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-purple:hover {
            background-color: #9433ff;
        }
        .btn-purple:active {
            transform: scale(0.98);
        }

        /* MODAL POPUP STYLES */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.75);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
            padding: 16px;
        }
        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }
        .modal-box {
            background-color: #12141c;
            border: 1px solid #1e2230;
            border-radius: 24px;
            width: 100%;
            max-width: 420px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.8);
            transform: scale(0.9);
            transition: transform 0.25s ease;
            position: relative;
        }
        .modal-overlay.active .modal-box {
            transform: scale(1);
        }
        .modal-body {
            padding: 24px;
            text-align: left;
        }
        .modal-header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }
        .modal-title {
            font-size: 14pt;
            font-weight: 700;
            color: #ffffff;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 6px;
            line-height: 1.3;
        }
        .btn-close {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #8c94a6;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            font-size: 14pt;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .btn-close:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }
        .modal-subtitle {
            color: #6c727f;
            font-size: 9.5pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }
        .code-box {
            background-color: #07080c;
            border: 1px solid #161924;
            border-radius: 12px;
            padding: 16px;
            font-family: "Courier New", Courier, monospace;
            font-size: 10pt;
            color: #38bdf8;
            word-break: break-all;
            white-space: pre-wrap;
            margin-bottom: 20px;
            max-height: 150px;
            overflow-y: auto;
            line-height: 1.5;
        }
        .toast {
            position: fixed;
            bottom: -60px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #8a2be2;
            color: white;
            padding: 14px 28px;
            border-radius: 30px;
            font-size: 11pt;
            font-weight: 600;
            box-shadow: 0 8px 24px rgba(138,43,226,0.4);
            transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 2000;
        }
        .toast.show {
            bottom: 40px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="badge">Roblox Script Hub</div>
        <h1>PlsHub Script</h1>
        <div class="subtitle">Select a game to get the script — copy with one click, paste into your executor.</div>

        <div class="card">
            <div class="image-container"></div>
            <div class="card-content">
                <div class="game-badge">Adventure</div>
                <div class="card-title">Blox Fruits</div>
                <div class="card-desc">PlsHub Script • Powerful, clean UI and frequently updated.</div>
                <button class="btn-purple" onclick="openModal()">Get Script</button>
            </div>
        </div>
    </div>

    <div id="scriptModal" class="modal-overlay" onclick="closeOutside(event)">
        <div class="modal-box">
            <div class="image-container" style="padding-top: 40%; background-image: url('dragon.jpg');"></div>
            <div class="modal-body">
                <div class="modal-header-row">
                    <h2 class="modal-title">🐱 PlsHub Script | Blox Fruits</h2>
                    <button class="btn-close" onclick="closeModal()">×</button>
                </div>
                <div class="modal-subtitle">Script — Copy & Paste into your executor</div>
                <div class="code-box" id="scriptCodeText">loadstring(game:HttpGet("https://raw.githubusercontent.com/ScriptPrime/PlsHub-BestUpdated/refs/heads/main/Txt"))()</div>
                <button class="btn-purple" onclick="copyScript()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Copy Script
                </button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast">Đã sao chép PlsHub Script thành công!</div>

    <script>
        const modal = document.getElementById('scriptModal');
        const toast = document.getElementById('toast');

        function openModal() {
            modal.classList.add('active');
        }

        function closeModal() {
            modal.classList.remove('active');
        }

        function closeOutside(e) {
            if (e.target === modal) {
                closeModal();
            }
        }

        function copyScript() {
            const code = document.getElementById('scriptCodeText').innerText;
            navigator.clipboard.writeText(code).then(() => {
                toast.classList.add('show');
                closeModal();
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 2500);
            }).catch(() => {
                alert('Trình duyệt lỗi, hãy copy thủ công đoạn code!');
            });
        }
    </script>

</body>
</html>
